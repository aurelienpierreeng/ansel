"<b>Profile data</b>\n"
"illuminant:  \t%.0f K \t%s\n"
"matrix in adaptation space:\n"
"<tt>%+.4f \t%+.4f \t%+.4f\n"
"%+.4f \t%+.4f \t%+.4f\n"
"%+.4f \t%+.4f \t%+.4f</tt>\n"
