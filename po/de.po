msgstr "% Anzeige"

#: ../src/iop/filmicrgb.c:4231
msgid "EV scene"
msgstr "EV Aufnahme"

#: ../src/iop/filmicrgb.c:4235
#, no-c-format
msgid "% camera"
msgstr "% Kamera"

#. Page DISPLAY
#: ../src/iop/filmicrgb.c:4271 ../src/iop/filmicrgb.c:5041
